<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <!-- Clear other sources if you want to enforce strict source control -->
        <clear />
    
        <!-- Standard official NuGet gallery -->
        <add key="nuget.org" value="https://nuget.org" protocolVersion="3" />
    
        <!-- Your local package source using a relative path -->
        <add key="LocalPackages" value="./local_packages" />
    </packageSources>

    <!-- Enforce source mapping to prevent dependency confusion attacks -->
    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
        <packageSource key="LocalPackages">
            <package pattern="*" />
        </packageSource>
    </packageSourceMapping>
</configuration>